{
  "id": "ddg-search",
  "name": "DuckDuckGo Web Search",
  "version": "1.0.0",
  "description": "Search the web using DuckDuckGo without requiring an API key",
  "author": "OpenClaw",
  "license": "MIT",
  
  "manifest": {
    "skills": [
      {
        "id": "ddg-search",
        "name": "DuckDuckGo Search",
        "description": "Perform web searches using DuckDuckGo"
      }
    ],
    
    "tools": [
      {
        "id": "ddg_search",
        "name": "Web Search (DuckDuckGo)",
        "description": "Search the web for information using DuckDuckGo - no API key required",
        "type": "command",
        "command": "ddg-search",
        "script": "ddg_search.py",
        
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of results (1-50)",
              "default": 10,
              "minimum": 1,
              "maximum": 50
            }
          },
          "required": ["query"]
        },
        
        "output": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The search query"
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "url": { "type": "string" },
                  "description": { "type": "string" },
                  "source": { "type": "string" }
                }
              },
              "description": "Search results"
            }
          }
        }
      }
    ],
    
    "commands": [
      {
        "name": "ddg-search",
        "description": "Search the web",
        "usage": "/ddg-search <query> [num_results]"
      }
    ]
  },
  
  "dependencies": {
    "python": ">=3.7",
    "pip": ["duckduckgo-search"]
  },
  
  "readmeUrl": "https://playbooks.com/skills/openclaw/skills/ddg-search",
  "repositoryUrl": "https://github.com/openclaw/skills/tree/main/ddg-search"
}
